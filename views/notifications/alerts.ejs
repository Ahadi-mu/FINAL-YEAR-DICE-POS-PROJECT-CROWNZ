<%- include('../partials/header') %>

<div class="page-header">
  <h2><i class="fas fa-bell"></i> Stock Alerts</h2>
</div>

<% if (alerts.length) { %>
<div class="alert alert-warning" style="margin:0 0 16px">
  <i class="fas fa-exclamation-triangle"></i>
  <strong><%= alerts.length %> product(s)</strong> need attention.
</div>
<% } %>

<div class="card">
  <div class="card-body" style="padding:0">
    <div class="table-responsive">
      <table>
        <thead><tr><th>Product</th><th>Category</th><th>Current Stock</th><th>Reorder Level</th><th>Alert</th><th>Action</th></tr></thead>
        <tbody>
        <% alerts.forEach(a => { %>
        <tr style="background:<%= a.alert_type === 'out_of_stock' ? '#fef2f2' : '#fffbeb' %>">
          <td><strong><%= a.product_name %></strong></td>
          <td><%= a.category_name %></td>
          <td class="<%= a.alert_type === 'out_of_stock' ? 'text-danger' : 'text-warning' %>">
            <strong><%= a.quantity_available %></strong>
          </td>
          <td><%= a.reorder_level %></td>
          <td>
            <% if (a.alert_type === 'out_of_stock') { %>
              <span class="badge badge-danger"><i class="fas fa-ban"></i> Out of Stock</span>
            <% } else { %>
              <span class="badge badge-warning"><i class="fas fa-exclamation-triangle"></i> Low Stock</span>
            <% } %>
          </td>
          <td><a href="/procurement/create" class="btn btn-success btn-sm"><i class="fas fa-plus"></i> Procure</a></td>
        </tr>
        <% }) %>
        <% if (!alerts.length) { %>
        <tr><td colspan="6"><div class="empty-state"><i class="fas fa-check-circle" style="color:var(--success)"></i><p>All stock levels are healthy!</p></div></td></tr>
        <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <%- include('../partials/footer') %>
</div>


