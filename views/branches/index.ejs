<%- include('../partials/header') %>

<div class="page-header">
  <h2><i class="fas fa-building"></i> Branches</h2>
  <button class="btn btn-primary" onclick="document.getElementById('createModal').style.display='flex'">
    <i class="fas fa-plus"></i> Add Branch
  </button>
</div>

<div class="card">
  <div class="card-body" style="padding:0">
    <div class="table-responsive">
      <table>
        <thead><tr><th>Branch Name</th><th>Location</th><th>Phone</th><th>Email</th><th>Users</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        <% branches.forEach(b => { %>
        <tr>
          <td><strong><%= b.branch_name %></strong></td>
          <td><%= b.location || '—' %></td>
          <td><%= b.phone || '—' %></td>
          <td><%= b.email || '—' %></td>
          <td><span class="badge badge-info"><%= b.user_count %> users</span></td>
          <td><span class="badge <%= b.status === 'active' ? 'badge-success' : 'badge-danger' %>"><%= b.status %></span></td>
          <td><button class="btn btn-outline btn-sm" onclick='openEdit(JSON.parse(decodeURIComponent("<%= encodeURIComponent(JSON.stringify(b)) %>")))'><i class="fas fa-edit"></i></button></td>
        </tr>
        <% }) %>
        <% if (!branches.length) { %><tr><td colspan="7"><div class="empty-state"><i class="fas fa-building"></i><p>No branches yet</p></div></td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Create Modal -->
<div id="createModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:12px;padding:28px;width:480px;max-width:95vw">
    <h3 style="margin-bottom:16px">Add Branch</h3>
    <form action="/branches/create" method="POST">
      <div class="form-group"><label>Branch Name *</label><input type="text" name="branch_name" required /></div>
      <div class="form-group"><label>Location</label><input type="text" name="location" placeholder="City, Area" /></div>
      <div class="form-row">
        <div class="form-group"><label>Phone</label><input type="text" name="phone" /></div>
        <div class="form-group"><label>Email</label><input type="email" name="email" /></div>
      </div>
      <div class="btn-group">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create</button>
        <button type="button" class="btn btn-secondary" onclick="document.getElementById('createModal').style.display='none'">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:2000;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:12px;padding:28px;width:480px;max-width:95vw">
    <h3 style="margin-bottom:16px">Edit Branch</h3>
    <form id="editForm" method="POST">
      <div class="form-group"><label>Branch Name *</label><input type="text" name="branch_name" id="eName" required /></div>
      <div class="form-group"><label>Location</label><input type="text" name="location" id="eLoc" /></div>
      <div class="form-row">
        <div class="form-group"><label>Phone</label><input type="text" name="phone" id="ePhone" /></div>
        <div class="form-group"><label>Email</label><input type="email" name="email" id="eEmail" /></div>
      </div>
      <div class="form-group"><label>Status</label><select name="status" id="eStatus"><option value="active">Active</option><option value="inactive">Inactive</option></select></div>
      <div class="btn-group">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update</button>
        <button type="button" class="btn btn-secondary" onclick="document.getElementById('editModal').style.display='none'">Cancel</button>
      </div>
    </form>
  </div>
  <%- include('../partials/footer') %>
</div>

<script>
function openEdit(b) {
  document.getElementById('eName').value = b.branch_name;
  document.getElementById('eLoc').value = b.location || '';
  document.getElementById('ePhone').value = b.phone || '';
  document.getElementById('eEmail').value = b.email || '';
  document.getElementById('eStatus').value = b.status;
  document.getElementById('editForm').action = `/branches/edit/${b.id}`;
  document.getElementById('editModal').style.display = 'flex';
}
</script>


