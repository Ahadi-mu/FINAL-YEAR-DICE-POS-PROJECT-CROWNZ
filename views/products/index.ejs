<%- include('../partials/header') %>

<div class="page-header">
  <h2><i class="fas fa-box"></i> Products</h2>
  <% if (user.role === 'manager' || user.role === 'director') { %>
  <a href="/products/create" class="btn btn-primary"><i class="fas fa-plus"></i> New Product</a>
  <% } %>
</div>

<!-- Filters -->
<form class="filters-bar" method="GET">
  <div class="form-group">
    <label>Search</label>
    <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Product name..." />
  </div>
  <div class="form-group">
    <label>Category</label>
    <select name="category_id">
      <option value="">All Categories</option>
      <% categories.forEach(c => { %>
      <option value="<%= c.id %>" <%= filters.category_id == c.id ? 'selected' : '' %>><%= c.category_name %></option>
      <% }) %>
    </select>
  </div>
  <div class="form-group">
    <label>Status</label>
    <select name="status">
      <option value="">All</option>
      <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
      <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
    </select>
  </div>
  <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Filter</button>
  <a href="/products" class="btn btn-secondary">Clear</a>
</form>

<div class="card">
  <div class="card-body" style="padding:0">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Product Name</th><th>Category</th><th>Cost Price</th>
            <th>Selling Price</th><th>Total Stock</th><th>Reorder Level</th>
            <th>Barcodes</th><th>Status</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
        <% products.forEach(p => { %>
        <tr>
          <td><strong><%= p.product_name %></strong><br><span class="text-muted" style="font-size:11px"><%= p.description || '' %></span></td>
          <td><%= p.category_name %></td>
          <td>UGX <%= Number(p.cost_price).toLocaleString() %></td>
          <td>UGX <%= Number(p.selling_price).toLocaleString() %></td>
          <td><%= p.total_stock %></td>
          <td><%= p.reorder_level %></td>
          <td>
            <a href="/products/<%= p.id %>/barcodes" class="badge badge-info" style="text-decoration:none">
              <%= p.barcode_count %> barcode<%= p.barcode_count != 1 ? 's' : '' %>
            </a>
          </td>
          <td><span class="badge <%= p.status === 'active' ? 'badge-success' : 'badge-danger' %>"><%= p.status %></span></td>
          <td>
            <div class="btn-group">
              <% if (user.role === 'manager' || user.role === 'director') { %>
              <a href="/products/edit/<%= p.id %>" class="btn btn-outline btn-sm"><i class="fas fa-edit"></i></a>
              <a href="/products/<%= p.id %>/barcodes" class="btn btn-secondary btn-sm"><i class="fas fa-barcode"></i></a>
              <% } %>
            </div>
          </td>
        </tr>
        <% }) %>
        <% if (!products.length) { %>
        <tr><td colspan="9"><div class="empty-state"><i class="fas fa-box-open"></i><p>No products found</p></div></td></tr>
        <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <%- include('../partials/footer') %>
</div>


