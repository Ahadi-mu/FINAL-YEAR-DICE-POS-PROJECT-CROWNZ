<%- include('../partials/header') %>

<div class="page-header">
  <h2><i class="fas fa-file-invoice"></i> Procurement Report</h2>
</div>

<form class="filters-bar" method="GET">
  <div class="form-group">
    <label>From Date</label>
    <input type="date" name="date_from" value="<%= filters.date_from || '' %>" />
  </div>
  <div class="form-group">
    <label>To Date</label>
    <input type="date" name="date_to" value="<%= filters.date_to || '' %>" />
  </div>
  <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Filter</button>
  <a href="/reports/procurement" class="btn btn-secondary">Clear</a>
</form>

<div class="card">
  <div class="card-body" style="padding:0">
    <div class="table-responsive">
      <table>
        <thead><tr><th>Reference</th><th>Supplier</th><th>Branch</th><th>Date</th><th>Total Cost</th><th>Recorded By</th></tr></thead>
        <tbody>
        <% let grandTotal = 0; %>
        <% procurements.forEach(p => { grandTotal += parseFloat(p.total_cost||0); %>
        <tr>
          <td><strong><%= p.reference_number || '—' %></strong></td>
          <td><%= p.supplier_name || '—' %></td>
          <td><%= p.branch_name %></td>
          <td><%= new Date(p.procurement_date).toLocaleDateString() %></td>
          <td>UGX <%= Number(p.total_cost).toLocaleString() %></td>
          <td><%= p.recorded_by %></td>
        </tr>
        <% }) %>
        <% if (procurements.length) { %>
        <tr style="background:#f0f2f5;font-weight:700">
          <td colspan="4" style="text-align:right;padding:12px">GRAND TOTAL</td>
          <td style="padding:12px">UGX <%= grandTotal.toLocaleString() %></td>
          <td></td>
        </tr>
        <% } %>
        <% if (!procurements.length) { %><tr><td colspan="6"><div class="empty-state"><i class="fas fa-clipboard"></i><p>No procurement records found</p></div></td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
  <%- include('../partials/footer') %>
</div>


