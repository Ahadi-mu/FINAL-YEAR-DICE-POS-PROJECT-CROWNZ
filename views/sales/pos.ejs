<%- include('../partials/header') %>

<div class="page-header">
  <h2><i class="fas fa-cash-register"></i> Point of Sale</h2>
  <a href="/sales/history" class="btn btn-outline btn-sm"><i class="fas fa-history"></i> Sales History</a>
</div>

<div class="pos-layout">
  <!-- Left: Product Search -->
  <div style="display:flex;flex-direction:column;gap:12px">
    <div class="card">
      <div class="card-body" style="padding:14px">
        <div class="pos-search">
          <label style="font-weight:600;margin-bottom:6px;display:block"><i class="fas fa-search"></i> Search Product / Scan Barcode</label>
          <input type="text" id="search-input" placeholder="Type product name or scan barcode..." style="font-size:15px" autocomplete="off" />
        </div>
        <div id="search-results" style="max-height:300px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius)"></div>
      </div>
    </div>

    <!-- Cart Items (mobile-friendly below search on small screens) -->
    <div class="card" style="display:none" id="mobile-cart-placeholder"></div>
  </div>

  <!-- Right: Cart Panel -->
  <div class="cart-panel">
    <div class="cart-header">
      <i class="fas fa-shopping-cart"></i> Cart
      <button onclick="cart=[];renderCart()" style="float:right;background:none;border:none;color:var(--danger);cursor:pointer;font-size:12px">
        <i class="fas fa-trash"></i> Clear
      </button>
    </div>
    <div class="cart-items" id="cart-items">
      <div class="empty-state"><i class="fas fa-shopping-cart"></i><p>Cart is empty<br><small>Search for a product to add</small></p></div>
    </div>
    <div class="cart-footer">
      <div class="cart-total" id="cart-total">UGX 0</div>
      <div class="form-group">
        <label>Amount Paid (UGX)</label>
        <input type="number" id="amount-paid" placeholder="0" min="0" step="100"
               oninput="calcChange()" style="font-size:16px;font-weight:600" />
      </div>
      <div id="change-display" style="font-size:14px;color:var(--success);margin-bottom:10px;font-weight:600"></div>
      <button onclick="processSale()" class="btn btn-success" style="width:100%;justify-content:center;padding:13px;font-size:15px">
        <i class="fas fa-check-circle"></i> Complete Sale
      </button>
    </div>
  </div>
  <%- include('../partials/footer') %>

</div>

<script>
function calcChange() {
  const paid = parseFloat(document.getElementById('amount-paid').value) || 0;
  const total = cart.reduce((s, i) => s + i.unit_price * i.quantity, 0);
  const change = paid - total;
  const el = document.getElementById('change-display');
  if (paid > 0) {
    el.textContent = change >= 0 ? `Change: UGX ${change.toLocaleString()}` : `⚠ Short by: UGX ${Math.abs(change).toLocaleString()}`;
    el.style.color = change >= 0 ? 'var(--success)' : 'var(--danger)';
  } else {
    el.textContent = '';
  }
}
</script>

