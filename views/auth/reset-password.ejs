<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; width: 100%; }
    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: linear-gradient(135deg, #41878b 0%, #288383 100%);
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh; padding: 24px;
    }
    .login-wrapper { width: 100%; max-width: 440px; }
    .login-card { background: #68ca99c5; border-radius: 16px; padding: 44px 48px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
    .login-logo { text-align: center; margin-bottom: 28px; }
    .login-logo i { font-size: 48px; color: #f0c040; }
    .login-logo h1 { font-size: 22px; font-weight: 700; color: #1f2937; margin-top: 10px; }
    hr { border: none; border-top: 1px solid #e5e7eb; margin: 0 0 22px; }
    .form-group { margin-bottom: 18px; }
    label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 7px; }
    input { display: block; width: 100%; padding: 11px 14px; border: 1.5px solid #d1d5db; border-radius: 8px; font-size: 14.5px; font-family: inherit; color: #1f2937; background: #fff; transition: border-color 0.2s, box-shadow 0.2s; }
    input:focus { outline: none; border-color: #1a56db; box-shadow: 0 0 0 3px rgba(26,86,219,0.12); }
    .btn { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 12px; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; font-family: inherit; cursor: pointer; transition: background 0.2s; }
    .btn-primary { background: #1a56db; color: #fff; } .btn-primary:hover { background: #1245a8; }
    .alert { display: flex; align-items: flex-start; gap: 9px; padding: 11px 14px; border-radius: 8px; font-size: 13.5px; margin-bottom: 18px; }
    .alert-error { background: #fde8e8; color: #c81e1e; border-left: 4px solid #e02424; }
    .back-link { text-align: center; margin-top: 18px; }
    .back-link a { color: #1a56db; font-size: 13px; text-decoration: none; }
    .back-link a:hover { text-decoration: underline; }
    @media (max-width: 480px) { .login-card { padding: 32px 24px; } }
  </style>
</head>
<body>
  <div class="login-wrapper">
    <div class="login-card">
      <div class="login-logo">
        <i class="fas fa-key"></i>
        <h1>Reset Password</h1>
      </div>
      <hr />
      <% if (error && error.length) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-triangle"></i><span><%= error[0] %></span></div>
      <% } %>
      <form action="/auth/reset-password/<%= token %>" method="POST">
        <div class="form-group">
          <label><i class="fas fa-lock"></i> New Password</label>
          <input type="password" name="password" placeholder="Minimum 6 characters" minlength="6" required autofocus />
        </div>
        <div class="form-group">
          <label><i class="fas fa-lock"></i> Confirm Password</label>
          <input type="password" name="confirm_password" placeholder="Repeat new password" required />
        </div>
        <button type="submit" class="btn btn-primary">
          <i class="fas fa-check"></i> Reset Password
        </button>
      </form>
      <div class="back-link">
        <a href="/auth/login"><i class="fas fa-arrow-left"></i> Back to Login</a>
      </div>
    </div>
  </div>
</body>
</html>
