<%- include('../partials/header') %>

<div class="page-header">
  <h2><i class="fas fa-receipt"></i> Receipt</h2>
  <div class="btn-group">
    <a href="/sales/receipt/<%= sale.id %>/pdf" class="btn btn-danger"><i class="fas fa-download"></i> Download PDF</a>
    <button onclick="window.print()" class="btn btn-outline"><i class="fas fa-print"></i> Print</button>
    <a href="/sales/history" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
</div>

<div class="receipt">
  <div class="receipt-header">
    <div style="font-size:20px;font-weight:800">CROWN STORES</div>
    <div style="font-size:12px;color:var(--text-muted)"><%= sale.branch_name %></div>
    <div style="font-size:11px;color:var(--text-muted)">Official Receipt</div>
  </div>

  <div style="margin:10px 0;font-size:12px">
    <div><strong>Receipt #:</strong> <%= sale.receipt_number %></div>
    <div><strong>Date:</strong> <%= new Date(sale.sale_date).toLocaleString() %></div>
    <div><strong>Served by:</strong> <%= sale.agent_name %></div>
  </div>

  <div style="border-top:1px dashed #ccc;border-bottom:1px dashed #ccc;padding:8px 0;margin:8px 0">
    <table style="width:100%;font-size:12px">
      <thead>
        <tr>
          <th style="text-align:left">Item</th>
          <th style="text-align:center">Qty</th>
          <th style="text-align:right">Price</th>
          <th style="text-align:right">Total</th>
        </tr>
      </thead>
      <tbody>
      <% items.forEach(item => { %>
      <tr>
        <td><%= item.product_name %></td>
        <td style="text-align:center"><%= item.quantity %></td>
        <td style="text-align:right"><%= Number(item.unit_price).toLocaleString() %></td>
        <td style="text-align:right"><%= Number(item.subtotal).toLocaleString() %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>

  <div class="receipt-total">
    <div style="display:flex;justify-content:space-between"><span>TOTAL:</span><span>UGX <%= Number(sale.total_amount).toLocaleString() %></span></div>
    <div style="display:flex;justify-content:space-between;font-size:13px"><span>Amount Paid:</span><span>UGX <%= Number(sale.amount_paid).toLocaleString() %></span></div>
    <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--success)"><span>Change:</span><span>UGX <%= Number(sale.change_given).toLocaleString() %></span></div>
  </div>

  <div style="text-align:center;font-size:11px;margin-top:14px;color:var(--text-muted)">
    Thank you for shopping with Crown Stores!<br>
    <strong>***OFFICIAL RECEIPT***</strong>
  </div>
  <%- include('../partials/footer') %>
</div>


