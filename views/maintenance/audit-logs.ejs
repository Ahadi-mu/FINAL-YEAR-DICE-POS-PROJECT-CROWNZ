<%- include('../partials/header') %>

<div class="page-header">
  <h2><i class="fas fa-shield-alt"></i> Audit Logs</h2>
  <a href="/maintenance" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<form class="filters-bar" method="GET">
  <div class="form-group">
    <label>User</label>
    <select name="user_id">
      <option value="">All Users</option>
      <% users.forEach(u => { %>
      <option value="<%= u.id %>" <%= filters.user_id == u.id ? 'selected' : '' %>>
        <%= u.full_name %> (<%= u.username %>)
      </option>
      <% }) %>
    </select>
  </div>
  <div class="form-group">
    <label>Module</label>
    <select name="module">
      <option value="">All Modules</option>
      <% ['Auth','Sales','Inventory','Procurement','Products','Categories','Users','Maintenance'].forEach(m => { %>
      <option value="<%= m %>" <%= filters.mod === m ? 'selected' : '' %>><%= m %></option>
      <% }) %>
    </select>
  </div>
  <div class="form-group">
    <label>From</label>
    <input type="date" name="date_from" value="<%= filters.date_from || '' %>" />
  </div>
  <div class="form-group">
    <label>To</label>
    <input type="date" name="date_to" value="<%= filters.date_to || '' %>" />
  </div>
  <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Filter</button>
  <a href="/audit-logs" class="btn btn-secondary">Clear</a>
</form>

<div class="card">
  <div class="card-body" style="padding:0">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>User</th>
            <th>Action</th>
            <th>Module</th>
            <th>Record ID</th>
            <th>IP Address</th>
            <th>Details</th>
          </tr>
        </thead>
        <tbody>
        <% logs.forEach(log => { %>
        <tr>
          <td style="white-space:nowrap;font-size:12px;color:var(--text-muted)">
            <%= new Date(log.created_at).toLocaleString() %>
          </td>
          <td>
            <strong><%= log.full_name || '—' %></strong><br>
            <span class="text-muted" style="font-size:11px"><%= log.username || '' %></span>
          </td>
          <td>
            <span class="badge
              <%= log.action.includes('LOGIN') ? 'badge-success' :
                  log.action.includes('FAILED') ? 'badge-danger' :
                  log.action.includes('DELETE') ? 'badge-danger' :
                  log.action.includes('CREATE') || log.action.includes('CREATED') ? 'badge-info' :
                  'badge-secondary' %>">
              <%= log.action %>
            </span>
          </td>
          <td><%= log.module || '—' %></td>
          <td><%= log.record_id || '—' %></td>
          <td style="font-size:12px;color:var(--text-muted)"><%= log.ip_address || '—' %></td>
          <td style="font-size:11px;max-width:200px;word-break:break-all">
            <% if (log.details) { %>
              <code style="font-size:10px"><%= JSON.stringify(log.details).substring(0, 80) %></code>
            <% } else { %>—<% } %>
          </td>
        </tr>
        <% }) %>
        <% if (!logs.length) { %>
        <tr>
          <td colspan="7">
            <div class="empty-state"><i class="fas fa-shield-alt"></i><p>No audit log entries found</p></div>
          </td>
        </tr>
        <% } %>
        </tbody>
      </table>
    </div>
    <% if (logs.length === 500) { %>
    <div style="padding:12px 16px;font-size:12px;color:var(--text-muted);border-top:1px solid var(--border)">
      <i class="fas fa-info-circle"></i> Showing latest 500 records. Use filters to narrow results.
    </div>
    <% } %>
  </div>
  <%- include('../partials/footer') %>
</div>


