<%- include('../partials/header') %>

<div class="page-header">
  <h2><i class="fas fa-cogs"></i> System Maintenance</h2>
  <a href="/audit-logs" class="btn btn-outline"><i class="fas fa-shield-alt"></i> Audit Logs</a>
</div>

<!-- System Settings -->
<div class="card" style="margin-bottom:24px">
  <div class="card-header"><span class="card-title"><i class="fas fa-sliders-h"></i> System Settings</span></div>
  <div class="card-body">
    <form action="/maintenance/settings" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
        <% settings.forEach(s => { %>
        <div class="form-group">
          <label><%= s.setting_key.replace(/_/g,' ').replace(/\b\w/g, l => l.toUpperCase()) %></label>
          <% if (s.setting_key === 'low_stock_notifications') { %>
          <select name="settings[<%= s.setting_key %>]">
            <option value="true" <%= s.setting_value === 'true' ? 'selected' : '' %>>Enabled</option>
            <option value="false" <%= s.setting_value === 'false' ? 'selected' : '' %>>Disabled</option>
          </select>
          <% } else { %>
          <input type="text" name="settings[<%= s.setting_key %>]" value="<%= s.setting_value %>" />
          <% } %>
          <% if (s.description) { %><small class="text-muted"><%= s.description %></small><% } %>
        </div>
        <% }) %>
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top:8px"><i class="fas fa-save"></i> Save Settings</button>
    </form>
  </div>
</div>

<!-- Bug Reports -->
<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-bug"></i> Bug Reports</span>
    <span class="badge badge-warning"><%= bugReports.filter(b => b.status === 'open').length %> open</span>
  </div>
  <div class="card-body" style="padding:0">
    <div class="table-responsive">
      <table>
        <thead><tr><th>Reporter</th><th>Module</th><th>Severity</th><th>Description</th><th>Date</th><th>Status</th><th>Update</th></tr></thead>
        <tbody>
        <% bugReports.forEach(b => { %>
        <tr>
          <td><%= b.reporter || '—' %></td>
          <td><%= b.module %></td>
          <td>
            <span class="badge <%= b.severity === 'critical' ? 'badge-danger' : b.severity === 'high' ? 'badge-warning' : 'badge-secondary' %>">
              <%= b.severity %>
            </span>
          </td>
          <td style="max-width:200px"><%= b.description.substring(0, 80) %><%= b.description.length > 80 ? '…' : '' %></td>
          <td class="text-muted"><%= new Date(b.created_at).toLocaleDateString() %></td>
          <td>
            <span class="badge <%= b.status === 'resolved' ? 'badge-success' : b.status === 'open' ? 'badge-danger' : 'badge-warning' %>">
              <%= b.status %>
            </span>
          </td>
          <td>
            <form action="/maintenance/bug/<%= b.id %>/status" method="POST" style="display:flex;gap:4px">
              <select name="status" style="padding:4px 6px;font-size:12px;border:1px solid var(--border);border-radius:4px">
                <option value="open" <%= b.status === 'open' ? 'selected' : '' %>>Open</option>
                <option value="in_progress" <%= b.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                <option value="resolved" <%= b.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
                <option value="closed" <%= b.status === 'closed' ? 'selected' : '' %>>Closed</option>
              </select>
              <button type="submit" class="btn btn-outline btn-sm"><i class="fas fa-check"></i></button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (!bugReports.length) { %><tr><td colspan="7"><div class="empty-state"><i class="fas fa-bug"></i><p>No bug reports</p></div></td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
  <%- include('../partials/footer') %>
</div>


